{
  "name": "postgrest-lite",
  "version": "0.1.0",
  "description": "CLI utility that runs Hono in front of PostgREST backed by in-memory PGlite.",
  "license": "MIT",
  "private": true,
  "bin": {
    "postgrest-lite": "bin/postgrest-lite.js"
  },
  "files": [
    "bin",
    "dist",
    "infra",
    "sql",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage cdk.out",
    "dev": "tsx src/cli/index.ts start",
    "start": "node bin/postgrest-lite.js start",
    "download": "node bin/postgrest-lite.js download",
    "doctor": "node bin/postgrest-lite.js doctor",
    "version:cli": "node bin/postgrest-lite.js version",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:build": "docker build -t postgrest-lite .",
    "docker:run": "docker run --rm -p 8080:8080 postgrest-lite",
    "cdk:synth": "cdk synth",
    "cdk:deploy": "cdk deploy"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "postgrestLite": {
    "defaultPostgrestVersion": "14.10"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@electric-sql/pglite-socket": "^0.1.4",
    "@hono/node-server": "^2.0.0",
    "@hono/standard-validator": "^0.2.0",
    "@zenfs/core": "^2.5.2",
    "adm-zip": "^0.5.16",
    "commander": "^14.0.3",
    "hono": "^4.12.15",
    "hono-openapi": "^1.3.0",
    "openapi-merge": "^1.3.3",
    "openapi-to-skills": "^0.3.0",
    "zod": "^3.24.0",
    "zod-openapi": "^4.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.15.19",
    "aws-cdk": "^2.1008.0",
    "aws-cdk-lib": "^2.251.0",
    "constructs": "^10.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}